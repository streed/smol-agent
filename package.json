{
  "name": "smol-agent",
  "version": "1.1.0",
  "description": "A small coding agent that runs in your terminal, powered by Ollama for local LLM hosting",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "smol-agent": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smol-ai/smol-agent.git"
  },
  "keywords": [
    "ollama",
    "llm",
    "ai",
    "agent",
    "coding",
    "terminal",
    "cli"
  ],
  "author": "Sean Reed",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/smol-ai/smol-agent/issues"
  },
  "homepage": "https://github.com/smol-ai/smol-agent#readme",
  "scripts": {
    "prepare": "npm run build",
    "start": "tsx src/index.ts",
    "build": "tsc && node scripts/prepare-dist.mjs",
    "build:strict": "tsc -p tsconfig.build.json && node scripts/prepare-dist.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:e2e": "node test/e2e/runner.js",
    "test:e2e:json": "node test/e2e/runner.js --json",
    "test:all": "npm test && npm run test:e2e",
    "harbor:export": "node harbor/export-scenarios.js",
    "harbor:export:dry-run": "node harbor/export-scenarios.js --dry-run",
    "harbor:build": "docker build -t smol-agent-harbor -f harbor/Dockerfile .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@mariozechner/pi-tui": "^0.55.4",
    "chalk": "^5.6.2",
    "glob": "^11.0.1",
    "graphology": "^0.26.0",
    "graphology-metrics": "^2.4.0",
    "ollama": "^0.6.3",
    "tiktoken": "^1.0.22"
  },
  "optionalDependencies": {
    "prebuild-install": "^7.1.3",
    "tree-sitter": "^0.25.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.3",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
