{
  "name": "smol-agent",
  "version": "1.0.0",
  "description": "A small coding agent that runs in your terminal, powered by Ollama for local LLM hosting",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "smol-agent": "./src/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smol-ai/smol-agent.git"
  },
  "keywords": [
    "ollama",
    "llm",
    "ai",
    "agent",
    "coding",
    "terminal",
    "cli"
  ],
  "author": "Sean Reed",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/smol-ai/smol-agent/issues"
  },
  "homepage": "https://github.com/smol-ai/smol-agent#readme",
  "scripts": {
    "start": "node src/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:e2e": "node test/e2e/runner.js",
    "test:e2e:json": "node test/e2e/runner.js --json",
    "test:all": "npm test && npm run test:e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@mariozechner/pi-tui": "^0.55.4",
    "chalk": "^5.6.2",
    "glob": "^11.0.1",
    "ollama": "^0.6.3",
    "tiktoken": "^1.0.22",
    "tree-sitter": "^0.25.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@jest/globals": "^29.7.0",
    "eslint": "^9.39.3",
    "globals": "^17.4.0",
    "jest": "^29.7.0"
  }
}
